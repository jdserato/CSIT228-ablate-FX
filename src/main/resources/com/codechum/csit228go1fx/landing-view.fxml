<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="apPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.codechum.csit228go1fx.LandingController">
   <children>
      <Label fx:id="lblHello" layoutX="75.0" layoutY="49.0" text="Hello, ">
         <font>
            <Font size="33.0" />
         </font>
      </Label>
      <GridPane layoutX="75.0" layoutY="110.0" prefHeight="247.0" prefWidth="478.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="232.0" minWidth="10.0" prefWidth="145.0" />
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="359.0" minWidth="10.0" prefWidth="333.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Name" />
            <Label text="Gender" GridPane.rowIndex="1" />
            <Label text="Program" GridPane.rowIndex="2" />
            <TextField fx:id="tfName" GridPane.columnIndex="1" />
            <HBox GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER">
               <children>
                  <RadioButton fx:id="rbMale" mnemonicParsing="false" text="Male">
                     <toggleGroup>
                        <ToggleGroup fx:id="gender" />
                     </toggleGroup></RadioButton>
                  <RadioButton fx:id="rbFemale" mnemonicParsing="false" text="Female" toggleGroup="$gender" />
               </children>
            </HBox>
            <ComboBox fx:id="cbProgram" prefWidth="150.0" promptText="Select program..." GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <TextArea fx:id="taResult" layoutX="128.0" layoutY="403.0" prefHeight="83.0" prefWidth="371.0" />
      <Button layoutX="274.0" layoutY="368.0" mnemonicParsing="false" onAction="#onSaveClicked" text="Save" />
      <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#onLogoutClicked" text="LogOut" />
   </children>
</AnchorPane>
